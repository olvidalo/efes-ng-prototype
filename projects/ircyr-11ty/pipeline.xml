<?xml version="1.0" encoding="UTF-8"?>
<pipeline name="IRCyR Eleventy">

  <meta siteDir="_output"/>

  <copyFiles name="copy-eleventy-site">
    <sourceFiles><files>source/website/**/*</files></sourceFiles>
    <output to="_assembly" stripPrefix="source/website"/>
  </copyFiles>

  <xsltTransform name="transform-epidoc">
    <sourceFiles><files>source/inscriptions/*.xml</files></sourceFiles>
    <stylesheet><files>source/stylesheets/lib/epidoc-to-html.xsl</files></stylesheet>
    <stylesheetParams>
      <param name="edn-structure">inslib</param>
      <param name="edition-type">interpretive</param>
      <param name="external-app-style">inslib</param>
      <param name="internal-app-style">none</param>
      <param name="leiden-style">panciera</param>
      <param name="line-inc">5</param>
      <param name="verse-lines">on</param>
      <param name="image-loc">https://ircyr2020.inslib.kcl.ac.uk/images/</param>
      <param name="bibloc"><files>source/authority/bibliography.xml</files></param>
      <param name="bib-link-template">../../bibliography/$1/</param>
      <param name="authority-dir"><dir>source/authority</dir></param>
    </stylesheetParams>
    <output to="_assembly/en/inscriptions"
            stripPrefix="source/inscriptions"
            extension=".html"/>
  </xsltTransform>

  <xsltTransform name="extract-epidoc-metadata">
    <sourceFiles><files>source/inscriptions/*.xml</files></sourceFiles>
    <stylesheet><files>source/indices-config.xsl</files></stylesheet>
    <stylesheetParams>
      <param name="languages">en</param>
      <param name="divine-file"><files>source/authority/divine.xml</files></param>
      <param name="emperors-file"><files>source/authority/emperors.xml</files></param>
      <param name="months-file"><files>source/authority/months.xml</files></param>
      <param name="places-file"><files>source/authority/places.xml</files></param>
      <param name="symbols-file"><files>source/authority/symbols.xml</files></param>
      <param name="bibliography-file"><files>source/authority/bibliography.xml</files></param>
    </stylesheetParams>
  </xsltTransform>

  <xsltTransform name="generate-eleventy-data">
    <sourceFiles><from node="extract-epidoc-metadata" output="transformed"/></sourceFiles>
    <stylesheet><files>source/stylesheets/lib/create-11ty-data.xsl</files></stylesheet>
    <stylesheetParams>
      <param name="layout">layouts/document.njk</param>
      <param name="tags">inscriptions</param>
      <param name="language">en</param>
    </stylesheetParams>
    <output to="_assembly/en/inscriptions"
            stripPrefix="source/inscriptions"
            extension=".11tydata.json"/>
  </xsltTransform>

  <xsltTransform name="aggregate-indices">
    <stylesheet><files>source/stylesheets/lib/aggregate-indices.xsl</files></stylesheet>
    <initialTemplate>aggregate</initialTemplate>
    <stylesheetParams>
      <param name="metadata-files"><from node="extract-epidoc-metadata" output="transformed"/></param>
      <param name="indices-config"><files>source/indices-config.xsl</files></param>
    </stylesheetParams>
    <output to="_assembly/_data/indices" filename="_summary.json"/>
  </xsltTransform>

  <xsltTransform name="aggregate-search-data">
    <stylesheet><files>source/stylesheets/lib/aggregate-search-data.xsl</files></stylesheet>
    <initialTemplate>aggregate</initialTemplate>
    <stylesheetParams>
      <param name="metadata-files"><from node="extract-epidoc-metadata" output="transformed"/></param>
      <param name="language">en</param>
    </stylesheetParams>
    <output to="_assembly/search-data" filename="documents_en.json"/>
  </xsltTransform>

  <xsltTransform name="transform-texts">
    <sourceFiles><files>source/texts/*.xml</files></sourceFiles>
    <stylesheet><files>source/stylesheets/lib/tei-to-html-11ty.xsl</files></stylesheet>
    <stylesheetParams>
      <!-- Eleventy page routing -->
      <param name="layout">layouts/base.njk</param>
      <param name="tags">texts</param>
      <!-- TEI rendering options -->
      <param name="divOffset">3</param>
      <param name="autoToc">false</param>
      <param name="numberHeadings">false</param>
      <param name="topNavigationPanel">false</param>
      <param name="bottomNavigationPanel">false</param>
      <param name="footnoteBackLink">true</param>
    </stylesheetParams>
    <output to="_assembly/en/texts" stripPrefix="source/texts" extension=".html"/>
  </xsltTransform>

  <eleventyBuild name="eleventy-build">
    <sourceDir><collect>_assembly</collect></sourceDir>
    <passthroughCopy>
      <param name="search-data">search-data</param>
      <param name="assets">assets</param>
    </passthroughCopy>
    <output to="_output"/>
  </eleventyBuild>

</pipeline>
