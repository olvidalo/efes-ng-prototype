{# Bibliography item detail — shows full citation and citing inscriptions. #}

{% set fc = item.fullCitation.en %}
{% if fc %}
<p class="full-citation">
    {%- if fc.authors %}{{ fc.authors }}, {% endif %}
    {%- if fc.title %}<i>{{ fc.title }}</i>{% endif %}
    {%- if fc.pubPlace %}, {{ fc.pubPlace }}{% endif %}
    {%- if fc.publisher %}, {{ fc.publisher }}{% endif %}
    {%- if fc.date %}, {{ fc.date }}{% endif -%}
    .
</p>
{% endif %}

<p><a href="/en/bibliography/">&larr; Back to list</a></p>

{% if item.references and item.references | length %}
<table class="data-table index-table">
    <thead>
        <tr>
            <th>Cited Range</th>
            <th>Inscriptions</th>
        </tr>
    </thead>
    <tbody>
    {% for ref in item.references %}
        <tr>
            <td>{{ ref.citedRange.en | default('-') }}</td>
            <td class="references">
                <a href="/en/inscriptions/{{ ref.documentId }}/"><strong>{{ ref.documentId }}</strong></a>
            </td>
        </tr>
    {% endfor %}
    </tbody>
</table>
{% endif %}
