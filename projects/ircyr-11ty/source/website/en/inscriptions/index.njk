---
layout: layouts/base.njk
title: Inscriptions
---

{# Collection name must match the "tags" stylesheet parameter in the generate-eleventy-data pipeline node #}
{% set documents = collections.inscriptions %}

<p class="index-intro">Browse all {{ documents | length | default(0) }} inscriptions in the
    collection.</p>

<table class="data-table inscription-table">
    <thead>
    <tr>
        <th>Document ID</th>
        <th>Title</th>
        <th>Findspot</th>
        <th>Dating</th>
        <th>Source File</th>
    </tr>
    </thead>
    <tbody>
    {% if documents and documents | length > 0 %}
        {# Sort by sortKey for natural ordering (A.1, A.2, ..., A.9, A.10, A.11...) #}
        {% set sorted = documents | sort(false, false, "data.sortKey") %}
        {% for document in sorted %}
            <tr>
                <td><a href="{{ document.url }}">{{ document.data.documentId }}</a></td>
                <td>{{ document.data.title }}</td>
                <td>{{ document.data.findspot }}</td>
                <td>{{ document.data.origDate }}</td>
                <td><code>{{ document.data.sourceFile }}</code></td>
            </tr>
        {% endfor %}
    {% else %}
        <tr>
            <td colspan="4">No inscriptions available.</td>
        </tr>
    {% endif %}
    </tbody>
</table>
