---
pagination:
  data: indices.bibliography.entries
  size: 1
  alias: item
permalink: "en/concordances/bibliography/{{ item.bibRef }}/index.html"
layout: layouts/base.njk
eleventyComputed:
  title: "Bibliography: {{ item.shortCitation }}"
---

<p class="full-citation">{{ item.fullCitation }}</p>

<p><a href="/en/concordances/bibliography/">&larr; Back to bibliography concordance</a></p>

<table class="index-table">
    <thead>
        <tr>
            <th>Cited Range</th>
            <th>Inscriptions</th>
        </tr>
    </thead>
    <tbody>
    {% for ref in item.references %}
        <tr>
            <td>{{ ref.citedRange | default('-') }}</td>
            <td class="references">
                <a href="/en/inscriptions/{{ ref.inscriptionId }}.html"><strong>{{ ref.inscriptionId }}</strong></a>
            </td>
        </tr>
    {% endfor %}
    </tbody>
</table>

{% include "partials/index-table-styles.njk" %}
