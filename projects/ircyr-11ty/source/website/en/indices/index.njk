---
layout: layouts/base.njk
title: Indices
permalink: en/indices/index.html
---

<p class="index-intro">Browse the entity indices for the inscription collection.</p>

<div class="indices-grid">
{% if indices._summary and indices._summary.indices %}
    {% for idx in indices._summary.indices %}
    <a href="/en/indices/{{ idx.id }}/" class="index-card">
        <h3>{{ idx.title[page.lang] | default(idx.title.en) }}</h3>
        {% if idx.description %}
        <p>{{ idx.description[page.lang] | default(idx.description.en) }}</p>
        {% endif %}
        <span class="entry-count">{{ idx.entryCount }} occurrences</span>
    </a>
    {% endfor %}
{% else %}
    <p>No indices available yet.</p>
{% endif %}
</div>
