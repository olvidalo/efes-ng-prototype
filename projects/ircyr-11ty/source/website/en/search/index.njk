---
layout: layouts/base.njk
title: Search
permalink: en/search/index.html
---

<link rel="stylesheet" href="/assets/css/efes-search.css">
<script src="https://rawcdn.githack.com/nextapps-de/flexsearch/0.8.2/dist/flexsearch.bundle.min.js"></script>
<script type="module" src="/assets/js/efes-search/index.js"></script>

<efes-search data-url="../../search-data/documents.json" text-fields="fullText,title">
    <aside class="efes-facet-sidebar">
        <h2>Filter Results</h2>

        <efes-date-range
            label="Date Range"
            from-label="From year"
            to-label="To year"
            hint="Use negative numbers for BCE"></efes-date-range>

        <efes-facet field="material" label="Material" expanded></efes-facet>
        <efes-facet field="objectType" label="Object Type" expanded></efes-facet>
        <efes-facet field="textType" label="Text Type"></efes-facet>
        <efes-facet field="language" label="Language" expanded></efes-facet>
        <efes-facet field="findspot" label="Findspot" expanded></efes-facet>
        <efes-facet field="repository" label="Repository"></efes-facet>

        <div class="efes-filter-actions">
            <button data-action="clear-all">Clear All Filters</button>
        </div>
    </aside>

    <div class="efes-search-main">
        <efes-search-input placeholder="Search inscriptions..."></efes-search-input>

        <efes-active-filters></efes-active-filters>

        <efes-results result-url="../../en/inscriptions/{documentId}.html">
            <template>
                <a>
                    <span class="doc-id" data-field="documentId"></span>
                    <span data-field="title"></span>
                </a>
                <div class="efes-result-details">
                    <span data-field="origDate"></span>
                    <span data-field="findspot"></span>
                    <span data-field="material"></span>
                </div>
            </template>
        </efes-results>
    </div>
</efes-search>

<style>
/* Page-level overrides */
main { margin-top: 0.5rem !important; padding-top: 0.5rem !important; }

.doc-id {
    display: inline-block;
    background: #edf2f7;
    color: #4a5568;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    font-family: monospace;
    font-size: 0.85rem;
    font-weight: 600;
}

/* IRCyr-specific: emoji icons for result details */
[data-field="origDate"]::before { content: '\1F4C5 '; }
[data-field="findspot"]::before { content: '\1F4CD '; }
[data-field="material"]::before { content: '\1F9F1 '; }
</style>
