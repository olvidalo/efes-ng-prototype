<?xml version="1.0" encoding="UTF-8"?>
<pipeline name="IRCyR Eleventy">

  <copyFiles name="copy-eleventy-site">
    <sourceFiles><files>1-input/eleventy-site/**/*</files></sourceFiles>
    <output to="2-intermediate/eleventy-site" from="1-input/eleventy-site"/>
  </copyFiles>

  <xsltTransform name="transform-epidoc">
    <sourceFiles><files>1-input/inscriptions/*.xml</files></sourceFiles>
    <stylesheet><files>1-input/epidoc-stylesheets/start-edition.xsl</files></stylesheet>
    <initialTemplate>inslib-body-structure</initialTemplate>
    <stylesheetParams>
      <param name="parm-edition-type">interpretive</param>
      <param name="parm-edn-structure">inslib</param>
      <param name="parm-external-app-style">inslib</param>
      <param name="parm-internal-app-style">none</param>
      <param name="parm-leiden-style">panciera</param>
      <param name="parm-line-inc">5</param>
      <param name="parm-verse-lines">on</param>
    </stylesheetParams>
    <output to="2-intermediate/eleventy-site/en/inscriptions"
            from="1-input/inscriptions"
            extension=".html"/>
  </xsltTransform>

  <xsltTransform name="extract-epidoc-metadata">
    <sourceFiles><files>1-input/inscriptions/*.xml</files></sourceFiles>
    <stylesheet><files>1-input/indices-config.xsl</files></stylesheet>
  </xsltTransform>

  <xsltTransform name="generate-eleventy-data">
    <sourceFiles><from node="extract-epidoc-metadata" output="transformed"/></sourceFiles>
    <stylesheet><files>1-input/lib/create-11ty-data.xsl</files></stylesheet>
    <stylesheetParams>
      <param name="layout">layouts/document.njk</param>
      <param name="tags">inscriptions</param>
    </stylesheetParams>
    <output to="2-intermediate/eleventy-site/en/inscriptions"
            from="1-input/inscriptions"
            extension=".11tydata.json"/>
  </xsltTransform>

  <xsltTransform name="aggregate-indices">
    <stylesheet><files>1-input/lib/aggregate-indices.xsl</files></stylesheet>
    <initialTemplate>aggregate</initialTemplate>
    <stylesheetParams>
      <param name="metadata-files"><from node="extract-epidoc-metadata" output="transformed"/></param>
      <param name="indices-config"><files>1-input/indices-config.xsl</files></param>
    </stylesheetParams>
    <output to="2-intermediate/eleventy-site/_data/indices" filename="_summary.json"/>
  </xsltTransform>

  <flexSearchIndex name="build-search-index">
    <documents><from node="extract-epidoc-metadata" output="transformed"/></documents>
    <idField>documentId</idField>
    <textFields>
      <field>fullText</field>
      <field>title</field>
    </textFields>
    <facetFields>
      <field>material</field>
      <field>objectType</field>
      <field>textType</field>
      <field>language</field>
      <field>findspot</field>
      <field>repository</field>
    </facetFields>
    <output to="2-intermediate/eleventy-site/search-data"/>
  </flexSearchIndex>

  <eleventyBuild name="eleventy-build">
    <sourceDir><collect>2-intermediate/eleventy-site</collect></sourceDir>
    <passthroughCopy>
      <param name="2-intermediate/eleventy-site/search-data">search-data</param>
      <param name="2-intermediate/eleventy-site/assets">assets</param>
    </passthroughCopy>
    <output to="3-output"/>
  </eleventyBuild>

</pipeline>
