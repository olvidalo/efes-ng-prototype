<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title | default('SigiDoc Collection') }}</title>

    <!-- Foundation 4.3.1 — required for XSLT-generated tabs and grid markup
         NOTE: Must use 4.3.1, not 4.3.2. The Section plugin in 4.3.2 has a regression
         where set_active_from_hash() only activates tabs when a URL hash matches a
         data-slug, so tabs with no hash never get their first section activated. -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/foundation/4.3.1/css/foundation.min.css"
          crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/foundation/4.3.1/css/normalize.min.css"
          crossorigin="anonymous">

    <!-- Typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Source+Sans+3:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,500&family=Noto+Serif:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="{{ '/assets/css/base.css' | url }}">
    <link rel="stylesheet" href="{{ '/assets/css/epidoc.css' | url }}">
    <link rel="stylesheet" href="{{ '/assets/css/project.css' | url }}">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/modernizr/2.6.2/modernizr.min.js"></script>
</head>
<body>
{% include "header.njk" %}

<div class="layout-grid">
    {% if not suppressTitle %}
    <h1>{{ title }}</h1>
    {% endif %}

    <main>
        {{ content | safe }}
    </main>
</div>

{% include "footer.njk" %}

<!-- jQuery + Foundation JS — required for XSLT-generated tabs and RTI viewer -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/1.10.2/jquery.min.js" crossorigin="anonymous"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/foundation/4.3.1/js/foundation.min.js"
        crossorigin="anonymous"></script>
<script>
    $(document).foundation();
</script>
</body>
</html>
