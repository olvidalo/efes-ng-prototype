<header>
    <div class="header-inner">
        <div class="header-content">
            <a href="/{{ language | default('en') }}/" class="site-title-link">
                <span class="site-title-abbr">SigiDoc</span>
                <span class="title-separator"></span>
                <span class="site-title-full">Sammlung Robert Feind</span>
            </a>

            {% if language %}
            <nav class="site-nav">
                {% set t = translations[language] %}
                {% set pathAfterLang = page.url | replace('/' + language + '/', '/') %}
                <a href="/{{ language }}/seals/" class="nav-link{% if pathAfterLang.startsWith('/seals/') %} nav-active{% endif %}">{{ t.nav.seals }}</a>
                <div class="nav-dropdown">
                    <a href="/{{ language }}/indices/" class="nav-link nav-dropdown-toggle{% if pathAfterLang.startsWith('/indices/') %} nav-active{% endif %}">{{ t.nav.indices }}</a>
                    <ul class="nav-dropdown-menu">
                        {% if indices and indices._summary and indices._summary.indices %}
                            {% for idx in indices._summary.indices %}
                            {% if idx.nav == "indices" or not idx.nav %}
                            <li><a href="/{{ language }}/indices/{{ idx.id }}/">{{ idx.title }}</a></li>
                            {% endif %}
                            {% endfor %}
                        {% else %}
                            <li><a href="/{{ language }}/indices/persons/">{{ t.indices.persons }}</a></li>
                            <li><a href="/{{ language }}/indices/places/">{{ t.indices.places }}</a></li>
                            <li><a href="/{{ language }}/indices/dignities/">{{ t.indices.dignities }}</a></li>
                            <li><a href="/{{ language }}/indices/offices/">{{ t.indices.offices }}</a></li>
                            <li><a href="/{{ language }}/indices/invocations/">{{ t.indices.invocations }}</a></li>
                        {% endif %}
                    </ul>
                </div>
                <a href="/{{ language }}/bibliography/" class="nav-link{% if pathAfterLang.startsWith('/bibliography/') %} nav-active{% endif %}">{{ t.nav.bibliography }}</a>
                <a href="/{{ language }}/search/" class="nav-link{% if pathAfterLang.startsWith('/search/') %} nav-active{% endif %}">{{ t.nav.search }}</a>
            </nav>

            <nav class="language-switcher">
                {% for lang in languages.codes %}
                    {% if lang == language %}
                        <span class="lang-current">{{ languages.labels[lang] }}</span>
                    {% else %}
                        <a href="{{ page.url | replace('/' + language + '/', '/' + lang + '/') }}" class="lang-link">{{ languages.labels[lang] }}</a>
                    {% endif %}
                {% endfor %}
            </nav>
            {% endif %}
        </div>
    </div>
</header>
