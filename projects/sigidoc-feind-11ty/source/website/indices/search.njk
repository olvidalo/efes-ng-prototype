---
pagination:
  data: languages.codes
  size: 1
  alias: langCode
permalink: "{{ langCode }}/search/index.html"
layout: layouts/base.njk
eleventyComputed:
  title: "{{ translations[langCode].search.pageTitle }}"
  language: "{{ langCode }}"
---

{% set t = translations[langCode] %}

<link rel="stylesheet" href="/assets/efes-search/efes-search.css">
<script type="module" src="/assets/efes-search/efes-search.js"></script>

<efes-search data-url="../../search-data/documents.json" text-fields="fullText,title">
    <aside class="efes-facet-sidebar">
        <h2>{{ t.search.filterResults }}</h2>

        <efes-date-range
            label="{{ t.search.dateRange }}"
            from-label="{{ t.search.fromYear }}"
            to-label="{{ t.search.toYear }}"></efes-date-range>

        <efes-facet field="material" label="{{ t.search.material }}" expanded></efes-facet>
        <efes-facet field="objectType" label="{{ t.search.objectType }}" expanded></efes-facet>
        <efes-facet field="language" label="{{ t.search.language }}" expanded></efes-facet>
        <efes-facet field="personalNames" label="{{ t.search.personalNames }}"></efes-facet>
        <efes-facet field="familyNames" label="{{ t.search.familyNames }}"></efes-facet>
        <efes-facet field="gender" label="{{ t.search.gender }}" expanded></efes-facet>
        <efes-facet field="milieu" label="{{ t.search.milieu }}"></efes-facet>
        <efes-facet field="placeNames" label="{{ t.search.placeNames }}"></efes-facet>
        <efes-facet field="dignities" label="{{ t.search.dignities }}"></efes-facet>
        <efes-facet field="civilOffices" label="{{ t.search.civilOffices }}"></efes-facet>
        <efes-facet field="ecclesiasticalOffices" label="{{ t.search.ecclesiasticalOffices }}"></efes-facet>
        <efes-facet field="militaryOffices" label="{{ t.search.militaryOffices }}"></efes-facet>
        <efes-facet field="collection" label="{{ t.search.collection }}"></efes-facet>
        <efes-facet field="metrical" label="{{ t.search.metrical }}"></efes-facet>
        <efes-facet field="monogram" label="{{ t.search.monogram }}"></efes-facet>

        <div class="efes-filter-actions">
            <button data-action="clear-all">{{ t.search.clearAll }}</button>
        </div>
    </aside>

    <div class="efes-search-main">
        <efes-search-input placeholder="{{ t.search.placeholder }}"></efes-search-input>

        <efes-active-filters></efes-active-filters>

        <efes-results result-url="../../{{ langCode }}/seals/{documentId}">
            <template>
                <a>
                    <span class="doc-id" data-field="documentId"></span>
                    <span data-field="title"></span>
                </a>
                <div class="efes-result-details">
                    <span data-field="origDate"></span>
                    <span data-field="material"></span>
                    <span data-field="collection"></span>
                </div>
            </template>
        </efes-results>
    </div>
</efes-search>
