---
pagination:
  data: languages.codes
  size: 1
  alias: langCode
permalink: "{{ langCode }}/indices/index.html"
layout: layouts/base.njk
eleventyComputed:
  title: "{{ translations[langCode].indices.pageTitle }}"
  language: "{{ langCode }}"
---

{% set t = translations[langCode] %}

<p class="list-summary">{{ t.indices.intro }}</p>

<div class="indices-grid">
{% if indices._summary and indices._summary.indices %}
    {% for idx in indices._summary.indices %}
    {% if idx.nav == "indices" or not idx.nav %}
    <a href="/{{ langCode }}/indices/{{ idx.id }}/" class="index-card">
        <h3>{{ idx.title }}</h3>
        {% if idx.description %}
        <p>{{ idx.description }}</p>
        {% endif %}
        <span class="entry-count">{{ idx.entryCount }} {{ t.indices.entries }}</span>
    </a>
    {% endif %}
    {% endfor %}
{% else %}
    <p>{{ t.indices.noIndices }}</p>
{% endif %}
</div>
