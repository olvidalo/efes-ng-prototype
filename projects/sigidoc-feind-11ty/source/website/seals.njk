---
pagination:
  data: languages.codes
  size: 1
  alias: langCode
permalink: "{{ langCode }}/seals/index.html"
layout: layouts/base.njk
eleventyComputed:
  title: "{{ translations[langCode].seals.pageTitle }}"
  language: "{{ langCode }}"
---

{% set t = translations[langCode].seals %}

{% set langSeals = [] %}
{% for seal in collections.seals %}
  {% if seal.data.language == langCode %}
    {% set langSeals = (langSeals.push(seal), langSeals) %}
  {% endif %}
{% endfor %}
{% set sortedSeals = langSeals | sort(false, false, "data.sortKey") %}

<p class="list-summary">{{ sortedSeals | length | default(0) }} {{ t.intro }}</p>

<table class="data-table seal-table">
    <thead>
    <tr>
        <th>{{ t.headers.documentId }}</th>
        <th>{{ t.headers.title }}</th>
        <th>{{ t.headers.category }}</th>
        <th>{{ t.headers.dating }}</th>
    </tr>
    </thead>
    <tbody>
    {% if sortedSeals and sortedSeals | length > 0 %}
        {% for seal in sortedSeals %}
            <tr onclick="window.location='{{ seal.url }}'" style="cursor:pointer">
                <td class="seal-id"><a href="{{ seal.url }}">{{ seal.data.documentId }}</a></td>
                <td><a href="{{ seal.url }}">{{ seal.data.title }}</a></td>
                <td>{{ seal.data.category }}</td>
                <td>{{ seal.data.origDate }}</td>
            </tr>
        {% endfor %}
    {% else %}
        <tr>
            <td colspan="4">{{ t.noSeals }}</td>
        </tr>
    {% endif %}
    </tbody>
</table>
