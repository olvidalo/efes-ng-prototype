{
  "name": "efes-ng-prototype",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm -w @efes-ng/core run build",
    "efes": "tsx packages/core/src/cli.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "overrides": {
    "vitepress-plugin-mermaid": {
      "vitepress": "$vitepress"
    }
  },
  "devDependencies": {
    "mermaid": "^11.14.0",
    "tsx": "^4.20.6",
    "vitepress": "^2.0.0-alpha.17",
    "vitepress-plugin-mermaid": "^2.0.17"
  }
}
