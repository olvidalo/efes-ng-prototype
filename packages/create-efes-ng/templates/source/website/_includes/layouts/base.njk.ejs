<!DOCTYPE html>
<html lang="<%- '{{ page.lang | default("en") }}' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title | default('<%= projectName %>') }}</title>

    <!-- Foundation 4.3.1 — required for XSLT-generated tabs -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/foundation/4.3.1/css/foundation.min.css" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/foundation/4.3.1/css/normalize.min.css" crossorigin="anonymous">

    <link rel="stylesheet" href="/assets/css/base.css">
    <link rel="stylesheet" href="/assets/css/epidoc.css">
    <link rel="stylesheet" href="/assets/css/project.css">
</head>
<body>
<%- '{% include "header.njk" %}' %>

<div class="layout-grid">
    <%- '{% if not suppressTitle %}' %>
    <h1>{{ title }}</h1>
    <%- '{% endif %}' %>

    <main>
        {{ content | safe }}
    </main>
</div>

<%- '{% include "footer.njk" %}' %>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/1.10.2/jquery.min.js" crossorigin="anonymous"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/foundation/4.3.1/js/foundation.min.js" crossorigin="anonymous"></script>
<script>
    $(document).foundation();
</script>
</body>
</html>
