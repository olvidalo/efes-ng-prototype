<header>
    <div class="header-inner">
        <div class="header-content">
            <h1 id="site-title">
                <a href="<%- '/{{ page.lang }}/' %>" class="site-title-link">
                    <!-- Website Title -->
                    <span class="site-title-full"><%= projectName %></span>
                </a>
            </h1>

            <!-- Navigation Menu -->
            <nav class="site-nav">
                <a href="<%- '/{{ page.lang }}/inscriptions/' %>" class="nav-link">Inscriptions</a>
                <a href="<%- '/{{ page.lang }}/search/' %>" class="nav-link">Search</a>
                <div class="nav-dropdown">
                    <a href="<%- '/{{ page.lang }}/indices/' %>" class="nav-link nav-dropdown-toggle">Indices</a>
                    <ul class="nav-dropdown-menu">
                        <%- '{% if indices and indices._summary and indices._summary.indices %}' %>
                            <%- '{% for idx in indices._summary.indices %}' %>
                            <%- '{% if idx.nav == "indices" or not idx.nav %}' %>
                            <li><a href="<%- '/{{ page.lang }}/indices/{{ idx.id }}/' %>"><%- '{{ idx.title }}' %></a></li>
                            <%- '{% endif %}' %>
                            <%- '{% endfor %}' %>
                        <%- '{% endif %}' %>
                    </ul>
                </div>
                <a href="<%- '/{{ page.lang }}/concordances/bibliography/' %>" class="nav-link">Bibliography</a>
            </nav>
        </div>
    </div>
</header>
