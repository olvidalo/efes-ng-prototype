<header>
    <div class="header-inner">
        <div class="header-content">
            <h1 id="site-title">
                <a href="<%- '/{{ page.lang }}/' %>" class="site-title-link">
                    <!-- Website Title -->
                    <span class="site-title-full"><%= projectName %></span>
                </a>
            </h1>

            <!-- Navigation Menu -->
            <nav class="site-nav">
                <a href="<%- '/{{ page.lang }}/inscriptions/' %>" class="nav-link">Inscriptions</a>
                <a href="<%- '/{{ page.lang }}/search/' %>" class="nav-link">Search</a>
                <!-- Indices dropdown menu -->
                <div class="nav-dropdown">
                    <a href="<%- '/{{ page.lang }}/indices/' %>" class="nav-link nav-dropdown-toggle">Indices</a>
                    <ul class="nav-dropdown-menu">
                        <!-- This will generate one menu entry for each index found in
                             _data/indices/_summary.json generated by stylesheets/lib/aggregate-indices.xsl -->
                        <%- '{% if indices and indices._summary and indices._summary.indices %}' %>
                            <%- '{% for idx in indices._summary.indices %}' %>
                            <%- '{% if idx.nav == "indices" or not idx.nav %}' %>
                            <li><a href="<%- '/{{ page.lang }}/indices/{{ idx.id }}/' %>"><%- '{{ idx.title[page.lang] | default(idx.title.en) }}' %></a></li>
                            <%- '{% endif %}' %>
                            <%- '{% endfor %}' %>
                        <%- '{% endif %}' %>
                    </ul>
                </div>
                <a href="<%- '/{{ page.lang }}/bibliography/' %>" class="nav-link">Bibliography</a>
            </nav>

            <!-- Uncomment for multi-language support (requires _data/languages.json):
            <nav class="language-switcher">
                {% for lang in languages.codes %}
                    {% if lang == page.lang %}
                        <span class="lang-current">{{ languages.labels[lang] }}</span>
                    {% else %}
                        <a href="{{ page.url | replace('/' + page.lang + '/', '/' + lang + '/') }}" class="lang-link">{{ languages.labels[lang] }}</a>
                    {% endif %}
                {% endfor %}
            </nav>
            -->
        </div>
    </div>
</header>
