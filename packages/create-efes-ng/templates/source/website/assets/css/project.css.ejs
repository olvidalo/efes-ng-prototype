/*
 * Project-specific CSS overrides for <%= projectName %>.
 *
 * Rules here override base.css by source order (loaded after it).
 *
 * To change the theme, override CSS custom properties:
 *
 *   :root {
 *     --primary: #1a5276;
 *     --accent: #cc9900;
 *   }
 *
 * See base.css :root for all available variables.
 */

/* Home page (en/index.njk) */
.home-hero {
    margin-bottom: 2rem;
}

.home-title {
    color: var(--primary);
    font-size: 2.5rem;
    font-weight: 600;
    margin: 0 0 0.25rem;
    padding: 0;
    border: none;
}

.home-section {
    line-height: 1.7;
}

.home-section code {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    background: var(--accent-faint);
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
}
